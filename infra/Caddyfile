# Kanakku Caddyfile
#
# Caddy serves plain HTTP internally on CADDY_PORT in all deployments.
# TLS is terminated upstream — by Tailscale, a Pi reverse proxy, or a VPS
# ingress layer. Caddy is not responsible for TLS certificates.
#
# Set PUBLIC_DOMAIN in .env to match your upstream's hostname (used for
# request routing). Set CADDY_PORT to whatever port your upstream forwards to.

{
    admin off
    # Reduce log verbosity in production
    log {
        level WARN
    }
}

http://{$PUBLIC_DOMAIN:localhost}:{$CADDY_PORT:8081} {
    encode gzip

    # Compress and cache static assets
    header /assets/* Cache-Control "public, max-age=31536000, immutable"
    header /*.js Cache-Control "public, max-age=3600"
    header /*.css Cache-Control "public, max-age=3600"

    # API → FastAPI backend
    reverse_proxy /api/* api:8765 {
        header_up X-Forwarded-Proto {scheme}
        health_uri /health
        health_interval 15s
    }

    # Health check pass-through
    reverse_proxy /health api:8765

    # Everything else → Nginx-served frontend static files
    reverse_proxy * frontend:80
}
