# ── Domain ────────────────────────────────────────────────────────────────────
# PUBLIC_DOMAIN is read by Caddy to determine the serving hostname.
#   Local dev / LAN:  localhost  (HTTP only, no TLS)
#   Pi 5 (LAN):       kanakku.local  (or the Pi's IP)
#   Pi 5 (Tailscale): your-hostname.tailnet-name.ts.net
#   Cloud VPS:        kanakku.yourdomain.com  (Caddy auto-provisions Let's Encrypt)
PUBLIC_DOMAIN=localhost
PUBLIC_BASE_URL=http://localhost:8765

# Port Caddy listens on (host and container). Change if port 80 is taken.
CADDY_PORT=9090

# External Docker network that your reverse proxy / tunnel container is on.
PROXY_NETWORK=pi-proxy-nw

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=kanakku
POSTGRES_USER=kanakku
POSTGRES_PASSWORD=changeme

# Used by the API and worker — points to the "db" service inside compose
DATABASE_URL=postgresql+asyncpg://kanakku:changeme@db:5432/kanakku

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=changeme-generate-with-openssl-rand-hex-32

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── LLM ───────────────────────────────────────────────────────────────────────
# "ollama" — use local Ollama (privacy-first, default)
# "none"   — disable LLM features entirely (safe default for dev)
LLM_BACKEND=none

# URL of the Ollama service — "ollama" is the compose service name
OLLAMA_HOST=http://ollama:11434

# Model to use (must be pulled first via init-ollama.sh or manually)
LLM_MODEL=qwen2.5:1.5b

# ── App ────────────────────────────────────────────────────────────────────────
DEBUG=false

# ── Dev mode ───────────────────────────────────────────────────────────────────
# DEV_MODE=true  — on every startup: wipe dev user data and reseed from fixtures.
#                  Also enables GET /api/v1/auth/dev-login (no-credential login).
#                  Dev user: dev@kanakku.com / dev-password
DEV_MODE=false

# VITE_DEV_MODE controls frontend auth behaviour (Vite build-time only):
#   bypass-auth — auto-login on app load via /auth/dev-login, skip login page
#                 (requires DEV_MODE=true on backend)
#   seeded      — normal login page with credentials pre-filled, signup disabled
#   (unset)     — full prod behaviour
VITE_DEV_MODE=

# Dev credentials — must match DEV_USER_EMAIL / DEV_USER_PASSWORD in backend/app/dev_seed.py
# Defaults are used if these are unset.
VITE_DEV_EMAIL=dev@kanakku.com
VITE_DEV_PASSWORD=dev-password
