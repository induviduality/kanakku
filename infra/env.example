# ── Domain ────────────────────────────────────────────────────────────────────
# PUBLIC_DOMAIN is read by Caddy to determine the serving hostname.
#   Local dev / LAN:  localhost  (HTTP only, no TLS)
#   Pi 5 (LAN):       kanakku.local  (or the Pi's IP)
#   Pi 5 (Tailscale): your-hostname.tailnet-name.ts.net
#   Cloud VPS:        kanakku.yourdomain.com  (Caddy auto-provisions Let's Encrypt)
PUBLIC_DOMAIN=localhost
PUBLIC_BASE_URL=http://localhost

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=kanakku
POSTGRES_USER=kanakku
POSTGRES_PASSWORD=changeme

# Used by the API and worker — points to the "db" service inside compose
DATABASE_URL=postgresql+asyncpg://kanakku:changeme@db:5432/kanakku

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=changeme-generate-with-openssl-rand-hex-32

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── LLM ───────────────────────────────────────────────────────────────────────
# "ollama" — use local Ollama (privacy-first, default)
# "none"   — disable LLM features entirely (safe default for dev)
LLM_BACKEND=none

# URL of the Ollama service — "ollama" is the compose service name
OLLAMA_HOST=http://ollama:11434

# Model to use (must be pulled first via init-ollama.sh or manually)
LLM_MODEL=qwen2.5:1.5b

# ── App ────────────────────────────────────────────────────────────────────────
DEBUG=false

# Dev mode: allows X-Dev-User-ID header to bypass auth (testing only)
# Creates seeded user: dev@kanakku.local / dev-password (login also works)
# Use .dev-config.yml + infra/load-dev-config.py to toggle all modes at once
# Or set individually:
# DEV_MODE_BACKEND=true   — enables backend dev mode (X-Dev-User-ID header, seeded user)
# DEV_MODE_FRONTEND=true  — enables frontend dev mode (HMR, debug info)
# DEV_MODE_INFRA=true     — enables infra dev mode (docker-compose overrides)
# Legacy: DEV_MODE (falls back to DEV_MODE_BACKEND if not set)
DEV_MODE_BACKEND=false
DEV_MODE_FRONTEND=false
DEV_MODE_INFRA=false
