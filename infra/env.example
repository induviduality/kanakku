# Domain
DOMAIN=kanakku.local

# Postgres
POSTGRES_DB=kanakku
POSTGRES_USER=kanakku
POSTGRES_PASSWORD=changeme

# Backend
DATABASE_URL=postgresql+asyncpg://kanakku:changeme@db:5432/kanakku
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
DEBUG=false

# LLM backend: "local" (Ollama) or "anthropic"
LLM_BACKEND=local
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Only required when LLM_BACKEND=anthropic
# ANTHROPIC_API_KEY=
